# ==========================================
# VIEWTUBE MINIMAL REPOSITORY .GITIGNORE
# ==========================================
# 
# This .gitignore keeps docs locally but excludes them from version control
# to minimize repository size for GitHub/Replit/Firebase deployment
#
# ESSENTIAL: Run this command if docs were previously committed:
# git rm -r --cached docs/ && git commit -m "Remove docs from tracking"
# ==========================================

# ================================
# DOCS - KEPT LOCALLY, NOT TRACKED
# ================================
docs/
docs/**/*
Roo-Code/
.billing/

# ================================
# DUPLICATE/COPY FOLDERS
# ================================
src copy/
docs/src copy/
scratch/

# ================================
# BACKUP AND TEMPORARY FILES
# ================================
*.bak
*.backup
*.fullbak
*.bak.*
*.backup.*
*.orig
*.tmp
*.temp
* copy.*
* copy
* copy 2.*
* copy 3.*
* copy 4.*
* copy 5.*
* copy 6.*
* copy 7.*
* copy 8.*
* copy 9.*

# ================================
# DEPENDENCIES AND BUILD OUTPUT
# ================================
node_modules/
dist/
build/
out/
*.tgz

# ================================
# VITE AND BUILD TOOLS
# ================================
.vite/
.vitest/
.parcel-cache/
.webpack-cache/
.terser-cache/
.storybook/

# ================================
# ENVIRONMENT AND CONFIG
# ================================
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
.env.test

# ================================
# OS GENERATED FILES
# ================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ================================
# EDITOR AND IDE FILES
# ================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/*.code-snippets
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*.swn
*.swn
*.swm
*.sublime-project
*.sublime-workspace
*.tmproj
*.code-workspace

# ================================
# LOGS AND CACHE
# ================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

.cache/
.eslintcache
.stylelintcache
.nyc_output/
.parcel-cache/
.webpack-cache/
.terser-cache/
.storybook/

# ================================
# TYPESCRIPT CACHE
# ================================
*.tsbuildinfo
tsconfig.tsbuildinfo

# ================================
# OPTIONAL NPM/YARN FILES
# ================================
.npm
.yarn-integrity
.yarn/
.pnp.*

# ================================
# TESTING AND COVERAGE
# ================================
coverage/
*.lcov
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.tox/
.nox/
test-results/
playwright-report/
html-report/

# ================================
# TEMPORARY AND MISCELLANEOUS
# ================================
tmp/
temp/
*.pid
*.seed
*.pid.lock
replay_pid*
hs_err_pid*

# ================================
# DATABASE AND LOCAL STORAGE
# ================================
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
*.sql

