   {
    title: "Series vs Standalone",
    subtitle: "Performance Variance",
    type: "CandlestickChart",
    provider: "google",
    data: () => {
     const header = ["Type", "Min", "Start", "End", "Max"]
     return [
      header,
      ["Series", 1000, 2000, 4000, 6000],
      ["Standalone", 500, 1500, 3000, 5000],
     ]
