       arr[0],
       arr[Math.floor(arr.length * 0.25)],
       arr[Math.floor(arr.length * 0.75)],
       arr[arr.length - 1],
      ]
     }
     return [
      header,
      ["SHORTS", ...getStats(shorts)],
      ["LONG-FORM", ...getStats(long)],
     ]
    },
    options: {
     legend: "none",
     bar: { groupWidth: "50%" },
     candlestick: {
      fallingColor: { strokeWidth: 2, stroke: "#000", fill: "#FF7497" },
