\pard\pardeftab720\partightenfactor0

\f5\fs28 \AppleTypeServices\AppleTypeServicesF65539 \cf8 \cb9 \strokec8 TypeScript\cb1 \
\
\pard\pardeftab720\partightenfactor0

\f6\fs21 \AppleTypeServices \cf8 \cb9 // MyVideo.tsx\
import \{ AbsoluteFill, interpolate, useCurrentFrame \} from 'remotion';\
\
export const MyVideo = () => \{\
  const frame = useCurrentFrame();\
  \
  // Animate opacity from 0 to 1 over the first 30 frames\
  const opacity = interpolate(frame, [0, 30], [0, 1], \{\
    extrapolateRight: 'clamp',\
  \});\
\
  return (\
    <AbsoluteFill style=\{\{ \
      backgroundColor: 'white', \
      justifyContent: 'center', \
      alignItems: 'center',\
      fontSize: 80,\
      fontWeight: 'bold'\
    \}\}>\
      <div style=\{\{ opacity \}\}>Hello, Napoleonic Historian!</div>\
    </AbsoluteFill>\
  );\
\};\
