\f4\b \AppleTypeServices\AppleTypeServicesF65539 \cf2 \cb4 \strokec2 1. The Multi-Layer Parallax Template (PNG & Stills)\cb1 \
\pard\pardeftab720\sa200\partightenfactor0

\f0\b0 \AppleTypeServices\AppleTypeServicesF65539 \cf2 \cb4 This template takes an array of layers (could be 3, 5, or more) and moves them at different speeds based on their "depth."\cb1 \
\pard\tx220\tx720\pardeftab720\li720\fi-720\sa200\partightenfactor0
\ls16\ilvl0
\f4\b \AppleTypeServices\AppleTypeServicesF65539 \cf2 \cb4 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Layer 0:
\f0\b0 \AppleTypeServices\AppleTypeServicesF65539  Background (slowest movement)\cb1 \
\ls16\ilvl0
\f4\b \AppleTypeServices\AppleTypeServicesF65539 \cb4 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Layer 1:
\f0\b0 \AppleTypeServices\AppleTypeServicesF65539  Midground (PNG with transparency)\cb1 \
\ls16\ilvl0
\f4\b \AppleTypeServices\AppleTypeServicesF65539 \cb4 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Layer 2:
\f0\b0 \AppleTypeServices\AppleTypeServicesF65539  Foreground (PNG with transparency - fastest movement)\cb1 \
\pard\pardeftab720\partightenfactor0

\f5\fs28 \AppleTypeServices\AppleTypeServicesF65539 \cf8 \cb9 \strokec8 TypeScript\cb1 \
\
\pard\pardeftab720\partightenfactor0

\f6\fs21 \AppleTypeServices \cf8 \cb9 import \{ AbsoluteFill, interpolate, useCurrentFrame \} from 'remotion';\
\
const ParallaxLayer = (\{ src, depth, index \}: \{ src: string; depth: number; index: number \}) => \{\
  const frame = useCurrentFrame();\
  \
  // Higher depth = faster movement. \
  // We move from 0 to -50 pixels multiplied by depth.\
  const translateX = interpolate(frame, [0, 300], [0, -50 * depth]);\
  const scale = interpolate(frame, [0, 300], [1, 1 + (0.05 * depth)]);\
\
  return (\
    <AbsoluteFill style=\{\{ \
      zIndex: index, \
      transform: `translateX($\{translateX\}px) scale($\{scale\})`,\
      display: 'flex',\
      justifyContent: 'center'\
    \}\}>\
      <img src=\{src\} style=\{\{ height: '100%', width: 'auto', objectFit: 'cover' \}\} />\
    </AbsoluteFill>\
  );\
\};\
\
export const 3DParallaxHook = (\{ layers \}: \{ layers: string[] \}) => \{\
  return (\
    <AbsoluteFill style=\{\{ backgroundColor: '#000', overflow: 'hidden' \}\}>\
      \{layers.map((src, i) => (\
        <ParallaxLayer key=\{src\} src=\{src\} depth=\{i + 1\} index=\{i\} />\
      ))\}\
    </AbsoluteFill>\
  );\
\};\
\pard\pardeftab720\partightenfactor0

