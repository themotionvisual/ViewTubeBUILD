\pard\tx220\tx720\pardeftab720\li720\fi-720\sa200\partightenfactor0
\ls5\ilvl0
\f6\fs28 \AppleTypeServices \cf8 \cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec8 useCurrentFrame()
\f0\fs32 \AppleTypeServices\AppleTypeServicesF65539 \cf2 \cb4 \strokec2 : This hook tells the component which frame is currently being rendered.\cb1 \
\ls5\ilvl0
\f6\fs28 \AppleTypeServices \cf8 \cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec8 interpolate()
