export const GlassHudHook = (\{ label, detail \}: \{ label: string, detail: string \}) => \{\
  const frame = useCurrentFrame();\
  \
  // Slide in from -600px to 40px\
  const x = interpolate(frame, [0, 20], [-600, 40], \{ extrapolateRight: 'clamp' \});\
  const opacity = interpolate(frame, [0, 15], [0, 1]);\
\
  return (\
    <div style=\{\{\
      position: 'absolute',\
      left: x,\
      top: '25%',\
      width: 400,\
      padding: 30,\
      background: 'rgba(255, 255, 255, 0.1)',\
      backdropFilter: 'blur(15px)',\
      border: '1px solid rgba(255, 255, 255, 0.2)',\
      borderRadius: '0 20px 20px 0',\
      opacity\
    \}\}>\
      <div style=\{\{ color: '#00ffcc', fontSize: 24 \}\}>\{label\}</div>\
      <div style=\{\{ color: 'white', fontSize: 48, fontWeight: 'bold' \}\}>\{detail\}</div>\
