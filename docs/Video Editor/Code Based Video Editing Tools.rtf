\f4\b \AppleTypeServices\AppleTypeServicesF65539 \cf2 \cb4 \strokec2 2. High-Performance Transitions (Video & Still)\cb1 \
\pard\pardeftab720\sa200\partightenfactor0

\f0\b0 \AppleTypeServices\AppleTypeServicesF65539 \cf2 \cb4 Instead of manual opacity math, use the 
\f6\fs28 \AppleTypeServices \cf8 \cb3 \strokec8 <TransitionSeries>
\f0\fs32 \AppleTypeServices\AppleTypeServicesF65539 \cf2 \cb4 \strokec2  component. This allows you to stack videos, images, or even the Parallax component above as "scenes" and animate between them.\cb1 \
\pard\pardeftab720\sa200\partightenfactor0

\f4\b \AppleTypeServices\AppleTypeServicesF65539 \cf2 \cb4 Installation:
\f0\b0 \AppleTypeServices\AppleTypeServicesF65539  
\f6\fs28 \AppleTypeServices \cf8 \cb3 \strokec8 npm i @remotion/transitions
\f0\fs32 \AppleTypeServices\AppleTypeServicesF65539 \cf2 \cb1 \strokec2 \
\pard\pardeftab720\partightenfactor0

\f5\fs28 \AppleTypeServices\AppleTypeServicesF65539 \cf8 \cb9 \strokec8 TypeScript\cb1 \
\
\pard\pardeftab720\partightenfactor0

\f6\fs21 \AppleTypeServices \cf8 \cb9 import \{ TransitionSeries, linearTiming, springTiming \} from "@remotion/transitions";\
import \{ slide, fade, flip, wipe \} from "@remotion/transitions/presentations";\
\
export const ShortsEditor = () => \{\
  return (\
    <TransitionSeries>\
      \{/* Scene 1: Multi-layer Parallax PNGs */\}\
      <TransitionSeries.Sequence durationInFrames=\{60\}>\
        <3DParallaxHook layers=\{['bg.jpg', 'subject_cutout.png', 'floating_particles.png']\} />\
      </TransitionSeries.Sequence>\
\
      \{/* Transition: A bouncy slide to the next scene */\}\
      <TransitionSeries.Transition\
        presentation=\{slide()\}\
        timing=\{springTiming(\{ config: \{ damping: 12 \} \})\}\
      />\
\
      \{/* Scene 2: High-Action B-Roll Video */\}\
      <TransitionSeries.Sequence durationInFrames=\{90\}>\
        <Video src=\{require('./action_clip.mp4')\} />\
      </TransitionSeries.Sequence>\
\
      \{/* Transition: A cinematic wipe */\}\
      <TransitionSeries.Transition\
        presentation=\{wipe(\{ direction: 'from-top' \})\}\
        timing=\{linearTiming(\{ durationInFrames: 15 \})\}\
      />\
\
      \{/* Scene 3: Still Image with a Ken Burns effect */\}\
      <TransitionSeries.Sequence durationInFrames=\{60\}>\
        <KenBurnsImage src="final_hook.jpg" />\
      </TransitionSeries.Sequence>\
    </TransitionSeries>\
  );\
\};\
\pard\pardeftab720\partightenfactor0

